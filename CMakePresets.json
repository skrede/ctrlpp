{
    "version": 6,
    "configurePresets": [
        {
            "name": "dev",
            "displayName": "Development (tests only)",
            "generator": "Ninja",
            "binaryDir": "${sourceDir}/build/dev",
            "cacheVariables": {
                "CMAKE_BUILD_TYPE": "Debug",
                "CMAKE_CXX_STANDARD": "23",
                "CMAKE_EXPORT_COMPILE_COMMANDS": "ON",
                "CTRLPP_BUILD_TESTS": "ON",
                "CTRLPP_CMAKE_FETCH_DEPS": "ON"
            }
        },
        {
            "name": "dev-full",
            "displayName": "Full development (tests + examples + fuzz + property)",
            "generator": "Ninja",
            "binaryDir": "${sourceDir}/build/dev-full",
            "cacheVariables": {
                "CMAKE_BUILD_TYPE": "Debug",
                "CMAKE_CXX_STANDARD": "23",
                "CMAKE_EXPORT_COMPILE_COMMANDS": "ON",
                "CTRLPP_BUILD_TESTS": "ON",
                "CTRLPP_BUILD_EXAMPLES": "ON",
                "CTRLPP_BUILD_FUZZ_TESTS": "ON",
                "CTRLPP_BUILD_PROPERTY_TESTS": "ON",
                "CTRLPP_CMAKE_FETCH_DEPS": "ON"
            }
        },
        {
            "name": "coverage",
            "displayName": "Coverage (GCC + gcov)",
            "generator": "Ninja",
            "binaryDir": "${sourceDir}/build/coverage",
            "cacheVariables": {
                "CMAKE_BUILD_TYPE": "Debug",
                "CMAKE_CXX_STANDARD": "23",
                "CMAKE_EXPORT_COMPILE_COMMANDS": "ON",
                "CMAKE_CXX_FLAGS": "--coverage -fprofile-arcs -ftest-coverage",
                "CTRLPP_BUILD_TESTS": "ON",
                "CTRLPP_ENABLE_COVERAGE": "ON",
                "CTRLPP_CMAKE_FETCH_DEPS": "ON"
            }
        }
    ],
    "buildPresets": [
        {
            "name": "dev",
            "configurePreset": "dev"
        },
        {
            "name": "dev-full",
            "configurePreset": "dev-full"
        },
        {
            "name": "coverage",
            "configurePreset": "coverage"
        }
    ],
    "testPresets": [
        {
            "name": "dev",
            "configurePreset": "dev",
            "output": {
                "outputOnFailure": true
            }
        },
        {
            "name": "coverage",
            "configurePreset": "coverage",
            "output": {
                "outputOnFailure": true
            }
        }
    ]
}
