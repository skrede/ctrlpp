@PACKAGE_INIT@

include(CMakeFindDependencyMacro)
find_dependency(Eigen3)
if (Eigen3_VERSION VERSION_LESS "3.4")
    message(FATAL_ERROR "ctrlpp requires Eigen >= 3.4, found ${Eigen3_VERSION}")
endif ()

include("${CMAKE_CURRENT_LIST_DIR}/ctrlppTargets.cmake")

# Optional implot component -- installed separately
if (EXISTS "${CMAKE_CURRENT_LIST_DIR}/ctrlppImplotTargets.cmake")
    find_dependency(imgui CONFIG)
    find_dependency(implot CONFIG)
    find_dependency(glfw3 CONFIG)
    find_dependency(OpenGL)
    include("${CMAKE_CURRENT_LIST_DIR}/ctrlppImplotTargets.cmake")
    set(ctrlpp_implot_FOUND TRUE)
else ()
    set(ctrlpp_implot_FOUND FALSE)
endif ()

check_required_components(ctrlpp)
